
public class Two_D_ArrayD {
    public static void main(String [] args){

        int[][] arr={{1,2,3,5},{2,3,6,7},{3,7,6,8}};
        for(int i=0;i<arr.length;i++){
            for(int j=0;j<arr[i].length;j++) {
                System.out.print(" "+arr[i][j]+" ");
            }
            System.out.println();
        }

    }
}
